DATABASE_URL="mysql://app_user:app_password@127.0.0.1:3306/employee_nhf"

AUTH_ACCESS_TOKEN_SECRET="replace-with-a-long-random-secret"
AUTH_CLEANUP_SECRET="replace-with-a-long-random-secret"
AUDIT_LOG_CLEANUP_SECRET="replace-with-a-long-random-secret"

PUBLIC_APPROVE_URL="https://approve.example.com"

SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="no-reply@example.com"
SMTP_PASS="replace-with-smtp-password"
IT_TEAM_EMAIL="it-team@example.com"
EMAIL_REQUEST_INAPP_RECIPIENT_EMAILS="it-admin@example.com,helpdesk@example.com"

LINE_IT_CHANNEL_ACCESS_TOKEN="replace-with-line-it-channel-access-token"
LINE_IT_CHANNEL_SECRET="replace-with-line-it-channel-secret"
LINE_STOCK_CHANNEL_ACCESS_TOKEN="replace-with-line-stock-channel-access-token"
LINE_STOCK_CHANNEL_SECRET="replace-with-line-stock-channel-secret"
LINE_WEBHOOK_URL="https://hooks.example.com/line"

MYSQL_ROOT_PASSWORD="replace-with-root-password"
MYSQL_DATABASE="employee_nhf"
MYSQL_USER="app_user"
MYSQL_PASSWORD="app_password"

# Feature Flags — omit for dev/test defaults, set to "true" to enable in production.
# Set to "false" to hide the module and return 404 from its API routes.
# Requires rebuild (npm run build) after changing
NEXT_PUBLIC_FEATURE_LEAVE=false
NEXT_PUBLIC_FEATURE_ITSUPPORT=false
