generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                     Int                @id @default(autoincrement())
  email                  String             @unique
  name                   String
  password               String
  role                   Role               @default(USER)
  tokenVersion           Int                @default(1)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  employeeId             Int?               @unique
  isActive               Boolean            @default(true)
  deletedAt              DateTime?
  comments               TicketComment[]
  ticketViews            TicketView[]
  assignedTickets        Ticket[]           @relation("AssignedTickets")
  reportedTickets        Ticket[]           @relation("ReportedTickets")
  deletedTickets         Ticket[]           @relation("DeletedTickets")
  employee               Employee?          @relation(fields: [employeeId], references: [id])
  auditLogs              AuditLog[]
  emailRequests          EmailRequest[]
  notifications          Notification[]
  refreshTokens          AuthRefreshToken[]
  stockTransactions      StockTransaction[]
  stockRequests          StockRequest[]     @relation("StockRequester")
  stockIssuedRequests    StockRequest[]     @relation("StockIssuer")
  stockCancelledRequests StockRequest[]     @relation("StockCanceller")
  ticketMutationIdempotencies TicketMutationIdempotency[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model AuthRefreshToken {
  id            String    @id @default(cuid())
  userId        Int
  tokenHash     String    @unique @db.VarChar(128)
  familyId      String    @db.VarChar(64)
  rotatedFromId String?   @unique @db.VarChar(36)
  expiresAt     DateTime
  revokedAt     DateTime?
  userAgent     String?   @db.VarChar(512)
  ipAddress     String?   @db.VarChar(64)
  lastUsedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("auth_refresh_tokens")
}

model Employee {
  id            Int            @id @default(autoincrement())
  firstName     String
  lastName      String
  phone         String?
  email         String         @unique
  position      String
  hireDate      DateTime       @default(now())
  status        EmployeeStatus @default(ACTIVE)
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  departmentId  Int
  affiliation   String?
  nickname      String?
  managerId     Int?
  dept          Department     @relation(fields: [departmentId], references: [id])
  manager       Employee?      @relation("ManagerToSubordinate", fields: [managerId], references: [id])
  subordinates  Employee[]     @relation("ManagerToSubordinate")
  user          User?
  leaveQuotas   LeaveQuota[]
  leaveRequests LeaveRequest[] @relation("LeaveRequester")
  approvals     LeaveRequest[] @relation("LeaveApprover")

  @@index([departmentId], map: "employees_departmentId_fkey")
  @@map("employees")
}

model Department {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  code        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]

  @@map("departments")
}

model Ticket {
  id           Int             @id @default(autoincrement())
  title        String
  description  String          @db.Text
  category     TicketCategory
  priority     TicketPriority  @default(MEDIUM)
  status       TicketStatus    @default(OPEN)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  resolvedAt   DateTime?
  closedAt     DateTime?
  cancelledAt  DateTime?
  deletedAt    DateTime?
  deletedById  Int?
  deleteReason String?         @db.VarChar(500)
  reportedById Int
  assignedToId Int?
  comments     TicketComment[]
  views        TicketView[]
  assignedTo   User?           @relation("AssignedTickets", fields: [assignedToId], references: [id])
  reportedBy   User            @relation("ReportedTickets", fields: [reportedById], references: [id])
  deletedBy    User?           @relation("DeletedTickets", fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([assignedToId], map: "tickets_assignedToId_fkey")
  @@index([deletedById], map: "tickets_deletedById_fkey")
  @@index([reportedById], map: "tickets_reportedById_fkey")
  @@map("tickets")
}

model TicketComment {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  createdAt DateTime @default(now())
  ticketId  Int
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([authorId], map: "ticket_comments_authorId_fkey")
  @@index([ticketId], map: "ticket_comments_ticketId_fkey")
  @@map("ticket_comments")
}

model TicketView {
  id       Int      @id @default(autoincrement())
  viewedAt DateTime @default(now())
  ticketId Int
  userId   Int
  ticket   Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([ticketId, userId])
  @@index([userId], map: "ticket_views_userId_fkey")
  @@map("ticket_views")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TicketCategory {
  HARDWARE
  SOFTWARE
  NETWORK
  ACCOUNT
  EMAIL
  PRINTER
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  CANCELLED
}

model TicketMutationIdempotency {
  id             String                     @id @default(cuid())
  userId         Int
  idempotencyKey String                     @db.VarChar(255)
  operation      TicketIdempotencyOperation
  requestHash    String                     @db.Char(64)
  resourceId     Int
  createdAt      DateTime                   @default(now())
  user           User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, idempotencyKey])
  @@index([createdAt])
  @@map("ticket_mutation_idempotency")
}

enum TicketIdempotencyOperation {
  TICKET_CREATE
  TICKET_COMMENT
}

enum NotificationOutboxType {
  TICKET_CREATED
  TICKET_UPDATED
  TICKET_CREATED_IN_APP
  TICKET_CREATED_LINE
  TICKET_CREATED_EMAIL_REPORTER
  TICKET_CREATED_EMAIL_IT
  TICKET_UPDATED_IN_APP_REPORTER
  TICKET_UPDATED_EMAIL_REPORTER
  TICKET_UPDATED_LINE
  TICKET_COMMENT_IN_APP
  EMAIL_REQUEST
  LEAVE_ACTION
  LEAVE_RESULT
  LEAVE_CANCELLED
  LEAVE_NOT_TAKEN_REQUESTED
  LEAVE_NOT_TAKEN_CONFIRMED
  STOCK_REQUEST_LINE
  STOCK_LOW_LINE
}

enum NotificationOutboxStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  DEAD
  SUPERSEDED
}

// Audit Log for tracking critical actions per agent.md security standards
model AuditLog {
  id         Int         @id @default(autoincrement())
  action     AuditAction
  entityType String // e.g., "User", "Employee", "Ticket"
  entityId   Int? // ID of the affected entity
  userId     Int? // User who performed the action
  userEmail  String? // Email for reference even if user deleted
  ipAddress  String? // Client IP address
  userAgent  String?     @db.Text // Browser/client info
  details    String?     @db.Text // JSON string with additional details
  createdAt  DateTime    @default(now())
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum AuditAction {
  // Authentication
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGE
  PASSWORD_RESET

  // Employee management
  EMPLOYEE_CREATE
  EMPLOYEE_UPDATE
  EMPLOYEE_DELETE
  EMPLOYEE_STATUS_CHANGE
  EMPLOYEE_IMPORT

  // Ticket management
  TICKET_CREATE
  TICKET_UPDATE
  TICKET_STATUS_CHANGE
  TICKET_ASSIGN
  TICKET_COMMENT
  TICKET_DELETE

  // Leave management
  LEAVE_REQUEST_CREATE
  LEAVE_REQUEST_APPROVE
  LEAVE_REQUEST_REJECT
  LEAVE_REQUEST_CANCEL
  LEAVE_REQUEST_NOT_TAKEN_REQUEST
  LEAVE_REQUEST_NOT_TAKEN_CONFIRM

  // Admin actions
  USER_CREATE
  USER_UPDATE
  USER_DELETE
  USER_ROLE_CHANGE

  // Stock management
  STOCK_ITEM_CREATE
  STOCK_ITEM_UPDATE
  STOCK_ITEM_DELETE
  STOCK_ADJUST
  STOCK_REQUEST_CREATE
  STOCK_REQUEST_ISSUE   @map("STOCK_REQUEST_APPROVE")
  STOCK_REQUEST_CANCEL  @map("STOCK_REQUEST_REJECT")
  STOCK_CATEGORY_CREATE
  STOCK_CATEGORY_DELETE

  // System
  SETTINGS_UPDATE
  DATA_EXPORT
  EMAIL_REQUEST
}

// Email Request History for tracking new employee email requests
model EmailRequest {
  id                  Int      @id @default(autoincrement())
  thaiName            String
  englishName         String
  phone               String
  nickname            String
  position            String
  department          String
  replyEmail          String
  needsDocumentSystem Boolean  @default(false)
  sharedDriveAccess   Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  requestedBy         Int
  user                User     @relation(fields: [requestedBy], references: [id])

  @@index([requestedBy])
  @@index([createdAt])
  @@map("email_requests")
}

// Password Reset Token for forgot password flow
model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(255) // SHA-256 hashed token
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// Transactional Outbox for reliable notifications (Email & LINE)
model NotificationOutbox {
  id            Int                      @id @default(autoincrement())
  type          NotificationOutboxType
  eventKey      String?                  @unique @db.VarChar(191)
  payload       String                   @db.Text // JSON string containing notification details
  status        NotificationOutboxStatus @default(PENDING)
  attempts      Int                      @default(0)
  nextAttemptAt DateTime                 @default(now())
  lastError     String?                  @map("error") @db.Text
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@index([status, nextAttemptAt])
  @@index([createdAt])
  @@map("notification_outbox")
}

// In-App Notifications for the Navigation Bar
model Notification {
  id          String           @id @default(cuid())
  userId      Int
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  message     String           @db.Text
  isRead      Boolean          @default(false)
  actionUrl   String?
  referenceId String? // ID of Ticket, Comment, etc.
  dedupeKey   String?          @unique
  createdAt   DateTime         @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  TICKET_CREATED
  NEW_COMMENT
  TICKET_UPDATED
  SYSTEM_ALERT
  LEAVE_REQUESTED
  LEAVE_APPROVED
  LEAVE_REJECTED
  LEAVE_CANCELLED
  LEAVE_NOT_TAKEN_REQUESTED
  LEAVE_NOT_TAKEN_CONFIRMED
  STOCK_REQUEST_NEW
  STOCK_ISSUED      @map("STOCK_APPROVED")
  STOCK_CANCELLED   @map("STOCK_REJECTED")
}

// ==========================================
// Leave Management System (HR)
// ==========================================

model LeaveQuota {
  id            String    @id @default(cuid())
  employeeId    Int
  year          Int // ปี ค.ศ. (เช่น 2026)
  leaveType     LeaveType
  totalHalfDays Int // โควตาทั้งหมด หน่วยครึ่งวัน (1 = ครึ่งวัน, 2 = หนึ่งวัน)
  usedHalfDays  Int       @default(0) // โควตาที่ใช้แล้ว หน่วยครึ่งวัน

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, year, leaveType]) // 1 คนมีโควตา 1 ประเภทต่อ 1 ปี
  @@map("leave_quotas")
}

model LeaveRequest {
  id           String      @id @default(cuid())
  employeeId   Int
  leaveType    LeaveType
  startDate    DateTime
  endDate      DateTime
  period       LeavePeriod @default(FULL_DAY)
  durationHalfDays Int // ระยะเวลาลาสุทธิ หน่วยครึ่งวัน (เช่น 3 = 1.5 วัน)
  reason       String      @db.Text
  emergencyReason String? @db.Text // เหตุผลฉุกเฉินเมื่อยื่นลาย้อนหลัง
  specialReason   String? @db.Text // เหตุผลพิเศษเมื่อขอลาเกินโควต้า
  overQuotaHalfDays Int   @default(0) // จำนวนที่เกินโควต้าตอนยื่นคำขอ หน่วยครึ่งวัน

  status LeaveStatus @default(PENDING)

  // ผู้อนุมัติ
  approverId   Int? // หัวหน้าที่ต้องอนุมัติตอนนั้น (ดึงจาก managerId ของพนักงาน)
  approvedAt   DateTime? // เวลาที่กดอนุมัติ/ปฏิเสธ
  rejectReason String?   @db.Text // เหตุผลที่ปฏิเสธ (ถ้ามี)
  notTakenReason        String?   @db.Text // โน๊ตเมื่ออนุมัติแล้วแต่ไม่ได้ใช้วันลา
  notTakenRequestedAt   DateTime?
  notTakenConfirmedAt   DateTime?
  notTakenConfirmedById Int?

  attachmentUrl String? @db.Text // เผื่อต้องแนบใบรับรองแพทย์

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee  @relation("LeaveRequester", fields: [employeeId], references: [id])
  approver Employee? @relation("LeaveApprover", fields: [approverId], references: [id])

  @@index([employeeId])
  @@index([approverId])
  @@index([status])
  @@index([notTakenRequestedAt])
  @@map("leave_requests")
}

enum LeaveType {
  SICK // ลาป่วย
  PERSONAL // ลากิจ
  VACATION // ลาพักร้อน
}

enum LeavePeriod {
  FULL_DAY // เต็มวัน (1.0)
  MORNING // ครึ่งวันเช้า (0.5)
  AFTERNOON // ครึ่งวันบ่าย (0.5)
}

enum LeaveStatus {
  PENDING // รออนุมัติ
  APPROVED // อนุมัติแล้ว
  REJECTED // ปฏิเสธ
  CANCELLED // ยกเลิกโดยพนักงาน
  NOT_TAKEN // อนุมัติแล้วแต่ไม่ได้ใช้วันลา
}

// ==========================================
// Stock & Requisition System
// ==========================================

model StockCategory {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       StockItem[]

  @@map("stock_categories")
}

model StockItem {
  id           Int                @id @default(autoincrement())
  name         String
  description  String?            @db.Text
  imageUrl     String?            @db.Text
  sku          String             @unique
  unit         String // รีม, ตลับ, ชิ้น
  quantity     Int                @default(0)
  minStock     Int                @default(0)
  categoryId   Int
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  category     StockCategory      @relation(fields: [categoryId], references: [id])
  transactions StockTransaction[]
  requestItems StockRequestItem[]
  variants     StockItemVariant[]

  @@index([categoryId])
  @@map("stock_items")
}

model StockItemVariant {
  id              Int                          @id @default(autoincrement())
  stockItemId     Int
  sku             String                       @unique
  unit            String
  quantity        Int                          @default(0)
  minStock        Int                          @default(0)
  imageUrl        String?                      @db.Text
  isActive        Boolean                      @default(true)
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  stockItem       StockItem                    @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  transactions    StockTransaction[]
  requestItems    StockRequestItem[]
  attributeValues StockVariantAttributeValue[]

  @@index([stockItemId])
  @@index([isActive])
  @@map("stock_item_variants")
}

model StockAttribute {
  id        Int                   @id @default(autoincrement())
  name      String                @unique
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  values    StockAttributeValue[]

  @@map("stock_attributes")
}

model StockAttributeValue {
  id          Int                          @id @default(autoincrement())
  attributeId Int
  value       String
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt
  attribute   StockAttribute               @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variants    StockVariantAttributeValue[]

  @@unique([attributeId, value])
  @@index([attributeId])
  @@map("stock_attribute_values")
}

model StockVariantAttributeValue {
  variantId        Int
  attributeValueId Int
  variant          StockItemVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue   StockAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@id([variantId, attributeValueId])
  @@index([attributeValueId])
  @@map("stock_variant_attribute_values")
}

model StockTransaction {
  id          Int               @id @default(autoincrement())
  itemId      Int
  variantId   Int?
  type        StockTxType
  quantity    Int // บวก=เพิ่ม, ลบ=ลด
  note        String?           @db.Text
  performedBy Int
  createdAt   DateTime          @default(now())
  item        StockItem         @relation(fields: [itemId], references: [id])
  variant     StockItemVariant? @relation(fields: [variantId], references: [id])
  user        User              @relation(fields: [performedBy], references: [id])

  @@index([itemId])
  @@index([variantId])
  @@index([performedBy])
  @@map("stock_transactions")
}

model StockRequest {
  id            Int                @id @default(autoincrement())
  requestedBy    Int
  idempotencyKey String             @db.VarChar(255)
  requestHash    String             @db.Char(64)
  projectCode    String             @db.VarChar(100)
  status        StockRequestStatus @default(PENDING_ISSUE)
  note          String?            @db.Text
  issuedById    Int?               @map("reviewedBy")
  issuedAt      DateTime?          @map("reviewedAt")
  cancelReason  String?            @map("rejectReason") @db.Text
  cancelledById Int?
  cancelledAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  requester     User               @relation("StockRequester", fields: [requestedBy], references: [id])
  issuer        User?              @relation("StockIssuer", fields: [issuedById], references: [id])
  canceller     User?              @relation("StockCanceller", fields: [cancelledById], references: [id])
  items         StockRequestItem[]

  @@unique([requestedBy, idempotencyKey])
  @@index([requestedBy])
  @@index([projectCode])
  @@index([status])
  @@index([issuedById])
  @@index([cancelledById])
  @@map("stock_requests")
}

model StockRequestItem {
  id        Int               @id @default(autoincrement())
  requestId Int
  itemId    Int
  variantId Int?
  quantity  Int
  request   StockRequest      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  item      StockItem         @relation(fields: [itemId], references: [id])
  variant   StockItemVariant? @relation(fields: [variantId], references: [id])

  @@index([requestId])
  @@index([itemId])
  @@index([variantId])
  @@map("stock_request_items")
}

enum StockTxType {
  IN // รับเข้าสต็อก
  OUT // เบิกออก (เมื่ออนุมัติ)
  ADJUST // ปรับยอดคงเหลือ
}

enum StockRequestStatus {
  PENDING_ISSUE   @map("PENDING") // รอจ่าย
  ISSUED          @map("APPROVED") // จ่ายแล้ว
  CANCELLED       @map("CANCELLED") // ยกเลิก
  REJECTED_LEGACY @map("REJECTED") // สถานะเก่าจาก flow เดิม
}
